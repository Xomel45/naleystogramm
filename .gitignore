# ── Директории сборки ─────────────────────────────────────────────────────────
build-linux/
build-win/
build-*/
*.build/
cmake-*/


# ── Артефакты деплоя ─────────────────────────────────────────────────────────
# builds/ содержит упакованные релизы и beta-бинарники.
# Не коммитим — они воспроизводимы из исходников через deploy.sh.
builds/

# ── AppImage артефакты ────────────────────────────────────────────────────────
*.AppImage
*.appimage
AppDir/

# ── Логи сборки ───────────────────────────────────────────────────────────────
build.log
*.log

# ── Скомпилированные объекты и файлы линкера ──────────────────────────────────
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.desktop

# ── Qt автогенерация (MOC, UIC, RCC) ─────────────────────────────────────────
*_autogen/
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp

# ── CMake генерированные файлы ────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# ── Qt переводы (генерируются из .ts) ─────────────────────────────────────────
# .ts файлы (исходники) — коммитим
# .qm файлы (бинарные, генерируются) — не коммитим
*.qm

# ── IDE и редакторы ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.user
*.suo

# ── Временные файлы ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig

# ── Секреты и конфигурация окружения ──────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# ── linuxdeploy инструменты (загружаются в процессе сборки) ──────────────────
appimage-tools/
linuxdeploy*.AppImage
linuxdeploy-plugin-*.AppImage
